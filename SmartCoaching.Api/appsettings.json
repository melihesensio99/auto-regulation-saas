{
  "Jwt": {
    "Issuer": "SmartCoachingApp",
    "Audience": "SmartCoachingApp",
    "SecretKey": "super_secret_key_which_should_be_long_enough_for_hmac_sha256"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/smartcoaching-log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Mistral": {
    "Model": "mistral-small-latest"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5434;Database=smartcoachingdb;Username=postgres;Password=Password123!"
  },
  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "daileireann17@gmail.com",
    "Password": "will-be-set-in-user-secrets",
    "FromEmail": "daileireann17@gmail.com",
    "FromName": "SmartCoaching"
  }
}
