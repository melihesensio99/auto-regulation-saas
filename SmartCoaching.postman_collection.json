{
	"info": {
		"name": "SmartCoaching API (Temiz Kurulum)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Antrenörler (Coaches)",
			"item": [
				{
					"name": "1. Yeni Antrenör Kaydı",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": { "mode": "raw", "raw": "{\r\n    \"firstName\": \"Melih\",\r\n    \"lastName\": \"Esensio\",\r\n    \"email\": \"melih@smartcoaching.com\",\r\n    \"password\": \"Password123!\"\r\n}" },
						"url": { "raw": "{{baseUrl}}/api/coaches", "host": [ "{{baseUrl}}" ], "path": [ "api", "coaches" ] }
					}
				}
			]
		},
		{
			"name": "2. Yetkilendirme (Auth)",
			"item": [
				{
					"name": "2. Sisteme Giriş (Login)",
					"event": [
						{
							"listen": "test",
							"script": { "exec": [ "var tokenValue = pm.response.text().replace(/\"/g, \"\");\r\npm.environment.set(\"token\", tokenValue);" ], "type": "text/javascript" }
						}
					],
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": { "mode": "raw", "raw": "{\r\n    \"email\": \"melih@smartcoaching.com\",\r\n    \"password\": \"Password123!\"\r\n}" },
						"url": { "raw": "{{baseUrl}}/api/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "login" ] }
					}
				}
			]
		},
		{
			"name": "3. Sporcular (Athletes)",
			"item": [
				{
					"name": "3. Yeni Sporcu Ekle",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": { "mode": "raw", "raw": "{\r\n    \"firstName\": \"Arda\",\r\n    \"lastName\": \"Guler\",\r\n    \"dateOfBirth\": \"2005-02-25T00:00:00Z\"\r\n}" },
						"url": { "raw": "{{baseUrl}}/api/athletes", "host": [ "{{baseUrl}}" ], "path": [ "api", "athletes" ] }
					}
				},
				{
					"name": "4. Kendi Sporcularımı Getir",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/api/athletes", "host": [ "{{baseUrl}}" ], "path": [ "api", "athletes" ] }
					}
				},
				{
					"name": "5. Sporcuya Hedef Ver (Update)",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
						"method": "PUT",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": { "mode": "raw", "raw": "{\r\n    \"targetCalories\": 3000,\r\n    \"targetSteps\": 12000\r\n}" },
						"url": { "raw": "{{baseUrl}}/api/athletes/<BURAYA_ID_YAPISTIRIN>/targets", "host": [ "{{baseUrl}}" ], "path": [ "api", "athletes", "<BURAYA_ID_YAPISTIRIN>", "targets" ] }
					}
				}
			]
		}
	]
}
